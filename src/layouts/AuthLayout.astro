---
import '@styles/global.css';

interface Props {
  pageTitle?: string;
}

const { pageTitle = 'Login' } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="RADIX - Sistema de Monitoreo Médico de Aislamiento Domiciliario" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle} | RADIX</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=IBM+Plex+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="relative flex min-h-screen items-center justify-center overflow-hidden bg-[#07050f] font-sans antialiased">

    <!-- Noise texture overlay -->
    <div class="pointer-events-none absolute inset-0 opacity-[0.03]"
         style="background-image: url('data:image/svg+xml,<svg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22><filter id=%22n%22><feTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/></filter><rect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22 opacity=%221%22/></svg>'); background-repeat: repeat; background-size: 128px;">
    </div>

    <!-- Dot grid -->
    <div class="pointer-events-none absolute inset-0 bg-dot-grid-dark opacity-60"></div>

    <!-- Primary glow — top center -->
    <div class="pointer-events-none absolute left-1/2 top-0 h-[600px] w-[800px] -translate-x-1/2 -translate-y-1/2 rounded-full"
         style="background: radial-gradient(ellipse, rgba(107,50,232,0.18) 0%, transparent 70%); filter: blur(40px);">
    </div>

    <!-- Secondary glow — bottom -->
    <div class="pointer-events-none absolute bottom-0 left-1/2 h-[400px] w-[600px] -translate-x-1/2 translate-y-1/2 rounded-full"
         style="background: radial-gradient(ellipse, rgba(59,32,128,0.12) 0%, transparent 70%); filter: blur(60px);">
    </div>

    <!-- Accent orb left -->
    <div class="pointer-events-none absolute -left-32 top-1/3 h-80 w-80 animate-float-slow rounded-full"
         style="background: radial-gradient(circle, rgba(107,50,232,0.1) 0%, transparent 70%); filter: blur(40px);">
    </div>

    <!-- Accent orb right -->
    <div class="pointer-events-none absolute -right-32 bottom-1/3 h-64 w-64 animate-float-reverse rounded-full"
         style="background: radial-gradient(circle, rgba(93,34,200,0.08) 0%, transparent 70%); filter: blur(40px);">
    </div>

    <!-- Horizontal scanline -->
    <div class="pointer-events-none absolute inset-x-0 top-1/2 h-px"
         style="background: linear-gradient(90deg, transparent, rgba(124,80,245,0.15) 30%, rgba(124,80,245,0.15) 70%, transparent);">
    </div>

    <!-- Main Content -->
    <div class="relative z-10 w-full max-w-6xl px-4 py-10 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2 lg:gap-24">

        <!-- Branding side (desktop only) -->
        <div class="hidden flex-col justify-center animate-fade-in lg:flex">

          <!-- Logo mark -->
          <div class="mb-10 flex items-center gap-4">
            <div class="relative flex h-16 w-16 items-center justify-center rounded-2xl"
                 style="background: rgba(107,50,232,0.15); box-shadow: inset 0 1px 0 rgba(255,255,255,0.08), 0 0 0 1px rgba(124,80,245,0.25), 0 8px 32px rgba(107,50,232,0.2);">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" viewBox="0 0 24 24" fill="none" stroke="url(#logograd)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <defs>
                  <linearGradient id="logograd" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" stop-color="#9878fa"/>
                    <stop offset="100%" stop-color="#6b32e8"/>
                  </linearGradient>
                </defs>
                <circle cx="12" cy="12" r="10" />
                <circle cx="12" cy="12" r="3" />
                <line x1="12" y1="2" x2="12" y2="6" />
                <line x1="12" y1="18" x2="12" y2="22" />
                <line x1="2" y1="12" x2="6" y2="12" />
                <line x1="18" y1="12" x2="22" y2="12" />
              </svg>
              <!-- Animated glow ring -->
              <div class="absolute inset-0 rounded-2xl animate-pulse-glow"
                   style="box-shadow: 0 0 20px rgba(124,80,245,0.3), inset 0 0 20px rgba(124,80,245,0.05);">
              </div>
            </div>
            <div>
              <p class="text-[10px] font-semibold uppercase tracking-[0.25em]" style="color: rgba(152,120,250,0.7); font-family: 'IBM Plex Mono', monospace;">Sistema Médico</p>
            </div>
          </div>

          <h1 class="font-display text-[64px] font-bold leading-none tracking-tighter xl:text-[80px]"
              style="background: linear-gradient(135deg, #fff 30%, rgba(152,120,250,0.8) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
            RADIX
          </h1>
          <p class="mt-4 text-lg leading-relaxed" style="color: rgba(255,255,255,0.38); font-weight: 300;">
            Panel de Monitoreo de<br/>Aislamiento Domiciliario
          </p>

          <!-- Stats row -->
          <div class="mt-10 flex gap-8">
            {[
              { value: '24/7', label: 'Monitoreo' },
              { value: '100%', label: 'Seguro' },
              { value: 'ISO', label: 'Certificado' },
            ].map(s => (
              <div>
                <p class="font-display text-2xl font-bold text-white">{s.value}</p>
                <p class="text-xs" style="color: rgba(255,255,255,0.3); font-family: 'IBM Plex Mono', monospace; text-transform: uppercase; letter-spacing: 0.1em;">{s.label}</p>
              </div>
            ))}
          </div>

          <!-- Feature pills -->
          <div class="mt-8 flex flex-wrap gap-2">
            {[
              { icon: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z', label: 'Acceso seguro' },
              { icon: 'M22 12h-4l-3 9L9 3l-3 9H2', label: 'Métricas en vivo' },
              { icon: 'M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z', label: 'Domiciliario' },
            ].map(f => (
              <div class="flex items-center gap-1.5 rounded-full px-3 py-1 text-xs font-medium"
                   style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08); color: rgba(255,255,255,0.4); backdrop-filter: blur(8px);">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" style="color: #9878fa;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d={f.icon} />
                </svg>
                {f.label}
              </div>
            ))}
          </div>

          <!-- Bottom divider -->
          <div class="mt-10 flex items-center gap-4">
            <div class="h-px flex-1" style="background: linear-gradient(90deg, rgba(124,80,245,0.3), transparent);"></div>
            <p style="font-family: 'IBM Plex Mono', monospace; font-size: 10px; color: rgba(255,255,255,0.15); text-transform: uppercase; letter-spacing: 0.2em;">v1.0 · Radiofarmacia</p>
          </div>
        </div>

        <!-- Form side -->
        <div class="mx-auto w-full max-w-md animate-slide-up lg:mx-0 lg:max-w-none">
          <slot />
        </div>

      </div>
    </div>
  </body>
</html>
