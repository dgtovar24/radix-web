---
import { ViewTransitions } from "astro:transitions";
import ThemeProvider from '../components/ThemeProvider';
import DashboardLayout from '../components/DashboardLayout';
import RegisterForm from '../components/auth/RegisterForm';
import '../styles/global.css';

const userCookie = Astro.cookies.get('radix-user')?.value;
let userName = 'User';
let userRole = 'Doctor';
let token = null;

if (userCookie) {
  try {
    const user = JSON.parse(decodeURIComponent(userCookie));
    userName = user.firstName || user.email || 'User';
    userRole = user.role || 'Doctor';
    token = user.token || user.id;
  } catch (e) {
    console.error('Failed to parse user cookie');
  }
}

if (!userRole) {
  return Astro.redirect('/login');
}
---
<!DOCTYPE html>
<html lang="es" class="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{userRole === 'Admin' ? 'Registrar Médico' : 'Registrar Paciente'} | RADIX</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <script is:inline>
    (function() {
      try {
        var saved = localStorage.getItem('radix-palette');
        if (saved) {
          var p = JSON.parse(saved);
          var c = p.colors;
          var root = document.documentElement;
          root.style.setProperty('--p', c.primary);
          root.style.setProperty('--p-l', c.primaryLight);
          root.style.setProperty('--p-50', c.surface || '#f5f2ff');
          root.style.setProperty('--p-100', c.surface || '#f5f2ff');
          root.style.setProperty('--p-200', c.primaryLight || '#d9cfff');
          root.style.setProperty('--s', c.secondary);
          root.style.setProperty('--b', c.background);
          root.style.setProperty('--sf', c.surface);
          root.style.setProperty('--t', c.text);
          root.style.setProperty('--t-s', c.textSecondary);
          root.style.setProperty('--t-m', c.textSecondary || '#9ca3af');
          root.style.setProperty('--a', c.accent);
          root.style.setProperty('--a-100', '#dbeafe');
          root.style.setProperty('--sc', c.success);
          root.style.setProperty('--sc-100', '#d1fae5');
          root.style.setProperty('--w', c.warning);
          root.style.setProperty('--w-100', '#fef3c7');
          root.style.setProperty('--e', c.error);
          root.style.setProperty('--e-100', '#fee2e2');
          root.style.setProperty('--br', c.border);
        }
      } catch (e) {}
    })();
  </script>
  <ViewTransitions />
</head>
<body style="background: var(--b);">
  <ThemeProvider client:load>
    <DashboardLayout client:load userName={userName} userRole={userRole}>
      <div style="max-width: 520px; margin: 0 auto;">
        <div style="margin-bottom: 24px;">
          <h1 style="font-size: 22; font-weight: 700; color: var(--t); font-family: var(--font-display); letter-spacing: -0.02em; margin: 0 0 6px;">
            {userRole === 'Admin' ? 'Registrar Médico' : 'Registrar Paciente'}
          </h1>
          <p style="font-size: 13; color: var(--t-s); margin: 0;">Complete los datos para añadir al sistema.</p>
        </div>
        <RegisterForm client:load creatorRole={userRole} creatorToken={token} />
      </div>
    </DashboardLayout>
  </ThemeProvider>
</body>
</html>