---
import { ViewTransitions } from "astro:transitions";
import ThemeProvider from '../components/ThemeProvider';
import DashboardLayout from '../components/DashboardLayout';
import UsuariosList from '../components/UsuariosList';
import '../styles/global.css';

const userCookie = Astro.cookies.get('radix-user')?.value;
let userName = 'User';
let userRole = 'Doctor';

if (userCookie) {
  try {
    const user = JSON.parse(decodeURIComponent(userCookie));
    userName = user.firstName || user.email || 'User';
    userRole = user.role || 'Doctor';
  } catch (e) {
    console.error('Failed to parse user cookie');
  }
}
const initialRightSidebarOpen = Astro.cookies.get('radix-right-sidebar')?.value !== 'false';
---
<!DOCTYPE html>
<html lang="es" class="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Usuarios | RADIX</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <script is:inline>
    (function() {
      try {
        var saved = localStorage.getItem('radix-palette');
        if (saved) {
          var p = JSON.parse(saved);
          var c = p.colors;
          var root = document.documentElement;
          root.style.setProperty('--p', c.primary);
          root.style.setProperty('--s', c.secondary);
          root.style.setProperty('--b', c.background || '#ffffff');
          root.style.setProperty('--sf', c.surface || '#f8fafc');
          root.style.setProperty('--t', c.text || '#111827');
          root.style.setProperty('--t-s', c.textSecondary || '#6b7280');
          root.style.setProperty('--br', c.border || '#f3f4f6');
        }
      } catch (e) {}
    })();
  </script>
  <ViewTransitions />
</head>
<body style="background: var(--b, #ffffff);">
  <ThemeProvider client:load>
    <DashboardLayout client:load userName={userName} userRole={userRole} initialRightSidebarOpen={initialRightSidebarOpen}>
      <UsuariosList client:load currentUserRole={userRole} />
    </DashboardLayout>
  </ThemeProvider>
</body>
</html>
