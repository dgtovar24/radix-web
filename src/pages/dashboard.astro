---
const userCookie = Astro.cookies.get('radix-user')?.value;
let userText = 'Médico';
let userRole = 'Doctor';
if (userCookie) {
  try {
    const user = JSON.parse(decodeURIComponent(userCookie));
    userText = user.firstName || user.email || 'Médico';
    userRole = user.role || 'Doctor';
  } catch {
    userText = decodeURIComponent(userCookie);
  }
}
const initial = userText.charAt(0).toUpperCase();
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard | RADIX</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800&family=DM+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
    :root{
      --radix-600:#6b32e8;--radix-500:#7c50f5;--radix-400:#9878fa;
      --bg:#07050f;--surface:rgba(255,255,255,0.04);--border:rgba(255,255,255,0.08);
      --text:#f1f0f5;--muted:rgba(255,255,255,0.38);
    }
    body{font-family:'DM Sans',system-ui,sans-serif;background:var(--bg);color:var(--text);min-height:100vh;-webkit-font-smoothing:antialiased;}

    /* Grid background */
    body::before{
      content:'';position:fixed;inset:0;pointer-events:none;
      background-image:radial-gradient(circle,rgba(255,255,255,0.04) 1px,transparent 1px);
      background-size:24px 24px;
    }

    /* Glow */
    body::after{
      content:'';position:fixed;top:0;left:50%;width:800px;height:500px;
      transform:translateX(-50%) translateY(-50%);border-radius:50%;pointer-events:none;
      background:radial-gradient(ellipse,rgba(107,50,232,0.15) 0%,transparent 70%);
      filter:blur(40px);
    }

    .page{position:relative;z-index:1;max-width:900px;margin:0 auto;padding:2.5rem 1.5rem 4rem;}

    /* Topbar */
    .topbar{display:flex;align-items:center;justify-content:space-between;margin-bottom:3rem;
      padding-bottom:1.5rem;border-bottom:1px solid var(--border);}
    .logo{display:flex;align-items:center;gap:0.75rem;}
    .logo-mark{width:36px;height:36px;border-radius:9px;display:flex;align-items:center;justify-content:center;
      background:rgba(107,50,232,0.2);box-shadow:0 0 0 1px rgba(124,80,245,0.3);}
    .logo-mark svg{width:18px;height:18px;stroke:#9878fa;fill:none;stroke-width:1.6;stroke-linecap:round;stroke-linejoin:round;}
    .logo-name{font-family:'Outfit',sans-serif;font-weight:700;font-size:1.1rem;color:#fff;letter-spacing:-0.01em;}
    .user-chip{display:flex;align-items:center;gap:0.6rem;}
    .avatar{width:34px;height:34px;border-radius:50%;display:flex;align-items:center;justify-content:center;
      font-family:'Outfit',sans-serif;font-weight:700;font-size:0.85rem;color:#fff;
      background:linear-gradient(135deg,var(--radix-600),var(--radix-500));
      box-shadow:0 0 0 2px rgba(124,80,245,0.3);}
    .user-info .name{font-weight:600;font-size:0.875rem;color:#fff;}
    .user-info .role-tag{font-size:0.7rem;font-family:'IBM Plex Mono',monospace;color:var(--muted);text-transform:uppercase;letter-spacing:0.08em;}

    /* Welcome */
    .welcome{margin-bottom:2.5rem;}
    .welcome h1{font-family:'Outfit',sans-serif;font-size:2rem;font-weight:700;color:#fff;line-height:1.2;}
    .welcome p{margin-top:0.5rem;color:var(--muted);font-size:0.95rem;}

    /* Cards grid */
    .cards{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:1rem;margin-bottom:2.5rem;}
    .card{
      padding:1.4rem;border-radius:16px;
      background:var(--surface);border:1px solid var(--border);
      text-decoration:none;
      transition:background 0.15s,border-color 0.15s,transform 0.15s;
      display:flex;flex-direction:column;gap:1rem;
    }
    .card:hover{background:rgba(255,255,255,0.06);border-color:rgba(124,80,245,0.4);transform:translateY(-2px);}
    .card-icon{width:42px;height:42px;border-radius:10px;display:flex;align-items:center;justify-content:center;}
    .card-icon svg{width:20px;height:20px;fill:none;stroke:currentColor;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round;}
    .icon-purple{background:rgba(152,120,250,0.12);color:#9878fa;}
    .icon-green{background:rgba(52,211,153,0.1);color:#34d399;}
    .icon-blue{background:rgba(96,165,250,0.1);color:#60a5fa;}
    .card-title{font-weight:600;font-size:0.9rem;color:#fff;}
    .card-desc{font-size:0.78rem;color:var(--muted);margin-top:0.25rem;line-height:1.5;}
    .card-arrow{margin-top:auto;font-size:0.75rem;color:rgba(152,120,250,0.6);
      font-family:'IBM Plex Mono',monospace;display:flex;align-items:center;gap:0.3rem;}

    /* Logout */
    .logout-btn{
      display:inline-flex;align-items:center;gap:0.5rem;
      padding:0.6rem 1.2rem;border-radius:8px;font-size:0.8rem;font-weight:500;
      background:rgba(240,62,62,0.08);border:1px solid rgba(240,62,62,0.2);
      color:rgba(248,113,113,0.8);text-decoration:none;cursor:pointer;
      transition:background 0.15s,border-color 0.15s,color 0.15s;
      font-family:inherit;
    }
    .logout-btn:hover{background:rgba(240,62,62,0.15);border-color:rgba(240,62,62,0.35);color:#f87171;}
    .logout-btn svg{width:14px;height:14px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;}

    /* Status bar */
    .status-bar{
      display:flex;align-items:center;gap:0.75rem;padding:0.75rem 1rem;border-radius:10px;
      background:rgba(52,211,153,0.06);border:1px solid rgba(52,211,153,0.15);
      font-size:0.8rem;color:rgba(52,211,153,0.8);
    }
    .live-dot{width:8px;height:8px;border-radius:50%;background:#34d399;
      box-shadow:0 0 0 4px rgba(52,211,153,0.15);animation:pulse 2s ease-in-out infinite;}
    @keyframes pulse{0%,100%{box-shadow:0 0 0 4px rgba(52,211,153,0.15);}50%{box-shadow:0 0 0 8px rgba(52,211,153,0.05);}}
  </style>
</head>
<body>
  <div class="page">

    <!-- Topbar -->
    <div class="topbar">
      <div class="logo">
        <div class="logo-mark">
          <svg viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="10"/>
            <circle cx="12" cy="12" r="3"/>
            <line x1="12" y1="2" x2="12" y2="6"/>
            <line x1="12" y1="18" x2="12" y2="22"/>
            <line x1="2" y1="12" x2="6" y2="12"/>
            <line x1="18" y1="12" x2="22" y2="12"/>
          </svg>
        </div>
        <span class="logo-name">RADIX</span>
      </div>
      <div style="display:flex;align-items:center;gap:1rem;">
        <div class="user-chip">
          <div class="avatar">{initial}</div>
          <div class="user-info">
            <div class="name">{userText}</div>
            <div class="role-tag">{userRole}</div>
          </div>
        </div>
        <form method="POST" action="/api/auth/logout" style="margin:0;">
          <button type="submit" class="logout-btn">
            <svg viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            Salir
          </button>
        </form>
      </div>
    </div>

    <!-- Welcome -->
    <div class="welcome">
      <h1>Bienvenido, {userText} 👋</h1>
      <p>Has iniciado sesión correctamente en el sistema RADIX.</p>
    </div>

    <!-- Status -->
    <div class="status-bar" style="margin-bottom:2rem;">
      <div class="live-dot"></div>
      <span>Sistema activo · Sesión iniciada</span>
    </div>

    <!-- Action Cards -->
    <div class="cards">

      <a href="/usuarios" class="card">
        <div class="card-icon icon-purple">
          <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <div>
          <div class="card-title">Ver Usuarios</div>
          <div class="card-desc">Lista completa de doctores y pacientes registrados en el sistema.</div>
        </div>
        <div class="card-arrow">Ver todos →</div>
      </a>

      {userRole === 'Admin' && (
        <a href="/register" class="card">
          <div class="card-icon icon-green">
            <svg viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
          </div>
          <div>
            <div class="card-title">Registrar Facultativo</div>
            <div class="card-desc">Crear una nueva cuenta de médico en la plataforma.</div>
          </div>
          <div class="card-arrow">Crear cuenta →</div>
        </a>
      )}
      
      {userRole === 'Doctor' && (
        <a href="/register" class="card">
          <div class="card-icon icon-green">
            <svg viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
          </div>
          <div>
            <div class="card-title">Registrar Paciente</div>
            <div class="card-desc">Añadir un nuevo paciente a la plataforma RADIX.</div>
          </div>
          <div class="card-arrow">Crear perfil →</div>
        </a>
      )}

      <a href="/login" class="card">
        <div class="card-icon icon-blue">
          <svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </div>
        <div>
          <div class="card-title">Cambiar Cuenta</div>
          <div class="card-desc">Iniciar sesión con una cuenta diferente.</div>
        </div>
        <div class="card-arrow">Ir al login →</div>
      </a>

    </div>

  </div>
</body>
</html>
