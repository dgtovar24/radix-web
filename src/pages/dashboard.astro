---
import { ViewTransitions } from "astro:transitions";
import ThemeProvider from '../components/ThemeProvider';
import DashboardLayout from '../components/DashboardLayout';
import DashboardStats from '../components/DashboardStats';
import '../styles/global.css';

const userCookie = Astro.cookies.get('radix-user')?.value;
let userName = 'Usuario';
let userRole = 'Doctor';

if (userCookie) {
  try {
    const user = JSON.parse(decodeURIComponent(userCookie));
    userName = user.firstName || user.email || 'Doctor';
    userRole = user.role || 'Doctor';
  } catch (e) {}
}

const today = new Date();
const hour = today.getHours();
const greeting = hour < 12 ? 'Buenos días' : hour < 18 ? 'Buenas tardes' : 'Buenas noches';
const dateStr = today.toLocaleDateString('es-ES', { weekday: 'long', day: 'numeric', month: 'long' });
const initialRightSidebarOpen = Astro.cookies.get('radix-right-sidebar')?.value !== 'false';
---
<!DOCTYPE html>
<html lang="es" class="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard | RADIX</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <script is:inline>
    (function() {
      try {
        var saved = localStorage.getItem('radix-palette');
        if (saved) {
          var p = JSON.parse(saved);
          var c = p.colors;
          var root = document.documentElement;
          root.style.setProperty('--p', c.primary);
          root.style.setProperty('--p-l', c.primaryLight);
          root.style.setProperty('--s', c.secondary);
          root.style.setProperty('--b', c.background || '#f7f8fa');
          root.style.setProperty('--sf', c.surface || '#ffffff');
          root.style.setProperty('--t', c.text || '#111827');
          root.style.setProperty('--t-s', c.textSecondary || '#6b7280');
          root.style.setProperty('--br', c.border || '#e5e7eb');
        }
      } catch (e) {}
    })();
  </script>
  <ViewTransitions />
</head>
<body style="background: var(--b, #f7f8fa);">
  <ThemeProvider client:load>
    <DashboardLayout client:load userName={userName} userRole={userRole} initialRightSidebarOpen={initialRightSidebarOpen}>
      <div style="animation: fadeIn 0.4s ease-out;">


        {/* Dashboard Stats */}
        <DashboardStats client:load />
      </div>
    </DashboardLayout>
  </ThemeProvider>
</body>
</html>
<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes livePing {
    75%, 100% { transform: scale(2.2); opacity: 0; }
  }
</style>